# ========== Public APIs (Optional - Improve rate limits) ==========
GITHUB_TOKEN=ghp_your_token_here          # GitHub: 60 → 5000 req/hour
HIBP_API_KEY=your_hibp_key_here           # Have I Been Pwned

# ========== Commercial APIs (v3.0 - Required for full features) ==========
HUNTER_API_KEY=your_hunter_key_here       # Hunter.io - Email verification
EMAILREP_API_KEY=your_emailrep_key_here   # EmailRep.io - Reputation scoring
CLEARBIT_API_KEY=your_clearbit_key_here   # Clearbit - Company enrichment

# Configuración
CACHE_TTL_DAYS=30
MAX_RETRIES=3
REQUEST_TIMEOUT=10

# Output
RESULTS_DIR=./results
